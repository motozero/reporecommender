{
  "name": "reporecommender",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc -p evals/tsconfig.json --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --test",
    "eval": "esbuild evals/run.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/eval.mjs --log-level=warning && node dist/eval.mjs",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.16.0",
    "zod": "^4.4.3"
  }
}
